# Copy this file to .env and fill in real values.
# .env is gitignored — NEVER commit real credentials.

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
VITE_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# ── Williams Trading Co. (live stock checks & automated order placement) ──────
# Base URL for the REST API
WT_API_BASE_URL="http://wholesale.williams-trading.com/rest/"
# Your account's customer ID
WT_CUSTOMER_ID="YOUR_CUSTOMER_ID"
# Account username
WT_USERNAME="YOUR_USERNAME"
# Account password  — change at https://williamstradingco.com/login.asp
WT_PASSWORD="YOUR_PASSWORD"
# API key generated in account settings at https://williamstradingco.com/login.asp
WT_API_KEY="YOUR_GENERATED_KEY_HERE"

# ── Eldorado Trading Co. (CIPP — FTP-based integration) ───────────────────────
# FTP credentials provided by Eldorado when enrolled in their CIPP program
ELDORADO_FTP_HOST="ftp.eldorado.net"
ELDORADO_FTP_USER="YOUR_ELDORADO_FTP_USERNAME"
ELDORADO_FTP_PASS="YOUR_ELDORADO_FTP_PASSWORD"
# Remote directories defined by Eldorado's CIPP spec
ELDORADO_ORDER_DIR="/Inbound"
ELDORADO_TRACKING_DIR="/Outbound"

# ── BigCommerce (webhook receiver & order detail API) ─────────────────────────
# Found in BC dashboard → Advanced Settings → API Accounts
BC_STORE_HASH="YOUR_STORE_HASH"
BC_ACCESS_TOKEN="YOUR_BC_ACCESS_TOKEN"
# Random secret token appended to your webhook URL to authenticate BC callbacks:
#   https://your-site.netlify.app/.netlify/functions/bigcommerce-webhook?secret=TOKEN
# Set this same value when registering the webhook in BC → Advanced Settings → Webhooks
BC_WEBHOOK_SECRET="YOUR_RANDOM_SECRET_TOKEN"
