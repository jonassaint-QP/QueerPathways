<style>
/* Ensure the age verification styles are specific and don't conflict with other styles */
#ageVerificationModal {
    display: none;
    position: fixed;
    z-index: 10000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
    background-color: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(5px);
}

#ageVerificationModal .avModalContent {
    background-color: #FFF;
    padding: 60px;
    width: 50%;
    text-align: center;
    border-radius: 10px;
    box-sizing: border-box; /* Added to include padding in the width */
}

#ageVerificationModal .avText {
    font-size: 1.25em;
    color: #000;
    margin-bottom: 20px;
}

#ageVerificationModal .avButton {
    background-color: #FFF;
    color: #000;
    padding: 10px 20px;
    font-size: 1em;
    margin: 10px;
    border: 2px solid #000;
    cursor: pointer;
    border-radius: 5px;
    transition: background-color 0.3s;
}

#ageVerificationModal .avButton:hover {
    background-color: #F5F5F5;
    border-color: #000;
}

/* Use specific body class to target when modal is active */
body.avBlurred > :not(#ageVerificationModal) {
    filter: blur(5px);
}

/* Responsive styles */
@media (max-width: 768px) {
    #ageVerificationModal .avModalContent {
        width: 80%;
        padding: 30px;
    }

    #ageVerificationModal .avText {
        font-size: 1em;
    }

    #ageVerificationModal .avButton {
        padding: 5px 10px;
        font-size: 0.9em;
    }
}
</style>

<div id="ageVerificationModal">
    <div class="avModalContent">
        <h1 class="avText">Welcome to...</h1>
        <h1 class="avText" style="font-size: 2em;">Welcome to our store</h1>
        <h2 class="avText">I agree that I am 18+ and understand that this website is not intended for those under 18.</h2>
        <button class="avButton" onclick="verifyAge(true)">Yes</button>
        <button class="avButton" onclick="verifyAge(false)">No</button>
        <p class="avText">By entering this site you are agreeing to the Terms of Use and Privacy Policy.</p>
    </div>
</div>

<script type="text/javascript">
function verifyAge(isOldEnough) {
    var modal = document.getElementById('ageVerificationModal');
    if (isOldEnough) {
        sessionStorage.setItem('ageVerified', 'true');
        modal.style.display = 'none';
        document.body.classList.remove('avBlurred');
    } else {
        alert("Sorry, you are not old enough to enter this site.");
        window.location.href = 'http://www.google.com';
    }
}

document.addEventListener('DOMContentLoaded', function() {
    var ageVerified = sessionStorage.getItem('ageVerified');
    if (ageVerified !== 'true') {
        var modal = document.getElementById('ageVerificationModal');
        modal.style.display = 'flex';
        document.body.classList.add('avBlurred');
    }
});
</script>
