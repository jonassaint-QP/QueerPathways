<script>
  document.addEventListener('DOMContentLoaded', () => {
    const wrapper = document.querySelector('.sticky-wrap-header__panel');
    if (!wrapper) return;

    const mq = window.matchMedia('(max-width: 1199.98px)');
    const THRESHOLD = 60;

    const getY = () =>
      window.pageYOffset ||
      document.scrollingElement?.scrollTop ||
      document.documentElement.scrollTop ||
      document.body.scrollTop ||
      0;

    const update = () => {
      if (!mq.matches) {
        wrapper.classList.remove('promo-hidden');
        return;
      }
      const y = getY();
      wrapper.classList.toggle('promo-hidden', y > THRESHOLD);
    };

    window.addEventListener('scroll', update, { passive: true, capture: true });
    document.addEventListener('scroll', update, { passive: true, capture: true });

    (document.scrollingElement || document.documentElement).addEventListener('scroll', update, { passive: true });

    window.addEventListener('resize', update);
    update();
  });
</script>


</div>
