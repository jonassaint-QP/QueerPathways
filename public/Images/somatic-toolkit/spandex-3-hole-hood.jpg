    grid-template-columns: repeat(1, minmax(0, 1fr)) !important;
}

@media (min-width: 1024px) {
  .lg\:al-grid-cols-3 {
    grid-template-columns: repeat(1,minmax(0,1fr)) !important;
  }
}

#loyaltyPageEarnPointsSection &gt; div &gt; div &gt; div &gt; div {
    grid-template-columns: repeat(1, minmax(0, 1fr)) !important;
}

@media (min-width: 768px) {
  .md\:al-max-w-xl {
    max-width: 628px !important;
  }
