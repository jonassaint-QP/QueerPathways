                  rounded-full
                  border
                  border-base-border
                  before:absolute
                  before:left-1/2
                  before:top-1/2
                  before:h-[1px]
                  before:w-[8px]
                  before:-translate-x-1/2
                  before:-translate-y-1/2
                  before:-rotate-45
                  before:bg-current
                  before:content-['']
                  after:absolute
                  after:left-1/2
                  after:top-1/2
                  after:h-[1px]
                  after:w-[8px]
                  after:-translate-x-1/2
                  after:-translate-y-1/2
                  after:rotate-45
                  after:bg-current
                  after:content-['']
                "
              >
                <span class="sr-only">Reset form</span>
              </span>
            </button>
