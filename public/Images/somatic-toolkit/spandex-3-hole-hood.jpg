      <script>
  // Check URL and set localStorage
  if (window.location.pathname === '/cart') {
    localStorage.setItem('redirect_and_open_drawer', 'true');
    window.location.href = '/';
  }

  document.addEventListener('DOMContentLoaded', () => {
    // Check localStorage on the homepage and simulate a click
    if (window.location.pathname === '/') {
      const shouldOpenDrawer = localStorage.getItem('redirect_and_open_drawer');

      if (shouldOpenDrawer === 'true') {
        const opener = document.querySelector('.cart-drawer-opener');
        if (opener) {
          opener.click();
        }
        // Remove the record from localStorage after the action is performed
        localStorage.removeItem('redirect_and_open_drawer');
      }
    }
  });
</script>

    

    <script>
      window.performance.mark('parse_head_start');
    </script>

    
    <script>
  function marks(name) {
    return {
      name,
      get start() {
        return `${this.name}_start`;
      },
      get end() {
        return `${this.name}_end`;
      },
    };
  }
</script>

    <script>
  window.markNames = {
    head: marks('parse_head'),
    body: marks('parse_body'),
    bodyLayout: marks('parse_body_layout'),
    bodyEndScripts: marks('parse_body_end_scripts'),
  };
</script>

    
    
