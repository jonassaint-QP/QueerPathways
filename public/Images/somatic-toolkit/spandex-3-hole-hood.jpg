<script>
  document.addEventListener('DOMContentLoaded', function () {
    const mediaQuery = window.matchMedia('(min-width: 768px)');

    function handleMediaChange(e) {
      const detailsUtilsElements = document.querySelectorAll('#footer details-utils');
      detailsUtilsElements.forEach((detailsUtil) => {
        const detailsElements = detailsUtil.querySelectorAll('details');
        detailsElements.forEach((details) => {
          if (e.matches) {
            details.setAttribute('open', true);
          } else {
            if (!details.classList.contains('opened--true')) {
              details.removeAttribute('open');
            }
          }
        });
      });
    }

    // Initial check
    handleMediaChange(mediaQuery);

    // Listen for changes
    mediaQuery.addEventListener('change', handleMediaChange);
  });
</script>


