        width: 28px;
        height: 28px;
        opacity: 0;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        transition: opacity 0.2s;
    }

    .appstle-loyalty-button {
        bottom: 24px;
        z-index: 999;
